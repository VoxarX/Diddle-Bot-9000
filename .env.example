# ============================================
# DIDDLE BOT - ENVIRONMENT CONFIGURATION
# ============================================

# Main bot token (REQUIRED)
# Get this from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_main_bot_token_here

# Bot Owner Discord ID (REQUIRED)
# Right-click your profile → Copy User ID (enable Developer Mode first)
OWNER_ID=Your-user-id

# Data file path (optional, defaults to diddle_leaderboard.json)
DATA_FILE=diddle_leaderboard.json

# Role prefix (optional, defaults to "Diddler ")
ROLE_PREFIX=Diddler 

# ============================================
# ULTIMATE DIDDLER SQUAD - 5 BOT TOKENS
# ============================================
# These are optional. Only needed for /ultimate-diddle command.
# Create 5 separate bot applications and paste their tokens here.

ULTIMATE_BOT_TOKEN_1=your_ultimate_bot_1_token_here
ULTIMATE_BOT_TOKEN_2=your_ultimate_bot_2_token_here
ULTIMATE_BOT_TOKEN_3=your_ultimate_bot_3_token_here
ULTIMATE_BOT_TOKEN_4=your_ultimate_bot_4_token_here
ULTIMATE_BOT_TOKEN_5=your_ultimate_bot_5_token_here

# Optional: customize the names of the 5 ultimate bots
ULTIMATE_BOT_NAME_1=Mommy-Diddeler
ULTIMATE_BOT_NAME_2=Brother-Diddler
ULTIMATE_BOT_NAME_3=Sister-Diddler
ULTIMATE_BOT_NAME_4=Dog-Diddler
ULTIMATE_BOT_NAME_5=Baby-Diddler
